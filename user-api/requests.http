# USER API ================================================================

@host=localhost:8080

### TODOS OS USUÁRIOS
GET /api/v1/users HTTP/1.1
Host: localhost:8080
Accept: application/json


### Get all users
# @name= getAllUsers

GET /api/v1/users HTTP/1.1
Host: {{host}}
Accept: application/json

### Create a new valid User
# @name = createNewUser

POST /api/v1/users HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "email": "batata@gmail.com",
    "password": "1234RT56",
    "handle": "papas",
    "name": "Kartofel",
    "roles": [
        "ROLE_USER"
    ],
    "company": "potato inc"
}


### Try and create an invalid User
# @name = tryCreateInvalidUser

POST /api/v1/users HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "email": "batata@potato.com",
    "password": "1234",
    "handle": "papas",
    "name": "Kartofel",
    "roles": [
        "ROLE_USER"
    ],
    "company": "potato inc"
}




### Create a new valid User
# @name = createNewUser

POST /api/v1/users HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "email": "julie@gmail.com",
    "password": "J784512505802",
    "handle": "juju",
    "name": "julie monteiro",
    "roles": [
        "ROLE_USER"
    ],
    "company": "julie inc"
}


### Create a new valid User
# @name = createNewUser

POST /api/v1/users HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "email": "leda@gmail.com",
    "password": "1234RT56784512",
    "handle": "lele",
    "name": "Leda",
    "roles": [
        "ROLE_USER"
    ],
    "company": "luffy inc"
}


# TICKET API ================================================================

### Listar todos os tickets
GET /api/v1/tickets HTTP/1.1
Host: {{host}}
Accept: application/json


### Buscar ticket por id
GET /api/v1/tickets/1 HTTP/1.1
Host: {{host}}
Accept: application/json


### Criar ticket válido — destinatário diferente do criador, com observadores
# @name = createTicket
POST /api/v1/tickets HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "acao": "Aprovar",
    "objeto": "Proposta comercial",
    "detalhes": "Proposta enviada pelo cliente em 10/07. Aguarda aprovação do gestor.",
    "criador": "julie@gmail.com",
    "destinatario": "leda@gmail.com",
    "observadores": ["batata@gmail.com"]
}


### Criar ticket válido — destinatário omitido (será igual ao criador)
POST /api/v1/tickets HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "acao": "Revisar",
    "objeto": "Contrato de serviço",
    "criador": "julie@gmail.com"
}


### Criar ticket válido — sem detalhes e sem observadores
POST /api/v1/tickets HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "acao": "Validar",
    "objeto": "Relatório mensal",
    "criador": "leda@gmail.com",
    "destinatario": "julie@gmail.com"
}


### [INVÁLIDO] Criar ticket sem ação
POST /api/v1/tickets HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "objeto": "Proposta comercial",
    "criador": "julie@gmail.com"
}


### [INVÁLIDO] Criar ticket sem objeto
POST /api/v1/tickets HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "acao": "Aprovar",
    "criador": "julie@gmail.com"
}


### [INVÁLIDO] Criar ticket sem criador
POST /api/v1/tickets HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "acao": "Aprovar",
    "objeto": "Proposta comercial"
}


### Colocar ticket em andamento (seta responsável)
PATCH /api/v1/tickets/1/status HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "status": "ANDAMENTO",
    "responsavel": "leda@gmail.com"
}


### Resolver ticket
PATCH /api/v1/tickets/1/status HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "status": "RESOLVIDO"
}


### Cancelar ticket com motivo
PATCH /api/v1/tickets/1/status HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "status": "CANCELADO",
    "motivo": "Cliente desistiu da solicitação."
}


### [INVÁLIDO] Colocar em andamento sem responsável
PATCH /api/v1/tickets/1/status HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "status": "ANDAMENTO"
}


### [INVÁLIDO] Cancelar sem motivo
PATCH /api/v1/tickets/1/status HTTP/1.1
Host: {{host}}
Content-Type: application/json

{
    "status": "CANCELADO"
}


### [INVÁLIDO] Buscar ticket inexistente
GET /api/v1/tickets/999 HTTP/1.1
Host: {{host}}
Accept: application/json


# VULNERABILITY REPORTS API ================================================================

### Listar primeira página (padrão: page=1, size=10)
GET /api/v1/vulnerability-reports HTTP/1.1
Host: {{host}}
Accept: application/json


### Listar segunda página com 10 itens
GET /api/v1/vulnerability-reports?page=2&size=10 HTTP/1.1
Host: {{host}}
Accept: application/json


### Listar terceira página com 10 itens
GET /api/v1/vulnerability-reports?page=3&size=10 HTTP/1.1
Host: {{host}}
Accept: application/json


### Listar com size 5 (mais páginas)
GET /api/v1/vulnerability-reports?page=1&size=5 HTTP/1.1
Host: {{host}}
Accept: application/json


### [INVÁLIDO] Page negativa
GET /api/v1/vulnerability-reports?page=-1&size=10 HTTP/1.1
Host: {{host}}
Accept: application/json


### [INVÁLIDO] Size zero
GET /api/v1/vulnerability-reports?page=1&size=0 HTTP/1.1
Host: {{host}}
Accept: application/json


### [INVÁLIDO] Size acima do limite (1000)
GET /api/v1/vulnerability-reports?page=1&size=1001 HTTP/1.1
Host: {{host}}
Accept: application/json
